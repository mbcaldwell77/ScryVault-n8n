# ===========================================
# ScryVault n8n Edition — Environment Variables
# ===========================================
# Copy to .env.local and fill in your values.
# Business logic (ISBN lookup, AI listing generation, eBay publishing)
# lives in n8n workflows. This app is the UI + database layer.


# n8n Webhook Base URL
# Points to your local (or remote) n8n instance webhook endpoint.
N8N_WEBHOOK_BASE_URL="https://n8n.automatonic.dev/webhook"


# Supabase (database stays in the app)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# eBay (kept for OAuth callback flow — n8n handles the actual API calls)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REDIRECT_URI=your-redirect-uri
EBAY_ENVIRONMENT=production
NEXT_PUBLIC_EBAY_ENVIRONMENT=PRODUCTION
EBAY_MERCHANT_LOCATION_KEY=your-ebay-merchant-location-key
EBAY_FULFILLMENT_POLICY_ID=your-ebay-fulfillment-policy-id
EBAY_PAYMENT_POLICY_ID=your-ebay-payment-policy-id
EBAY_RETURN_POLICY_ID=your-ebay-return-policy-id


# Agent SDK (OFF by default — Gemini via n8n handles generation/decisions
# unless AGENT_MODE=true flips the flag)
AGENT_MODE=false

# Anthropic API key — ONLY required when AGENT_MODE=true.
# Powers the in-process Agent SDK loop for:
#   - /api/listings/generate     (user-facing, routed here when flag is on)
#   - /api/agents/listing        (internal, n8n-callable)
#   - /api/agents/stale-listing  (internal, n8n-callable)
# Leave unset while AGENT_MODE=false — the Gemini/n8n path doesn't need it.
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for n8n -> /api/agents/* calls. The same value must be set in
# your n8n instance env vars (used in the x-agent-secret header). 48-char
# random string is fine. Only required when AGENT_MODE=true AND n8n workflows
# are wired to call agent endpoints.
AGENT_INTERNAL_SECRET=generate-a-random-48-char-string


# NOTE: GOOGLE_BOOKS_API_KEY is NOT needed here.
# ISBN lookup is handled by n8n workflows.
